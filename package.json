{
  "name": "r3ngine_mobile",
  "main": "expo-router/entry",
  "version": "1.2.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "npx eas build -p android --profile production",
    "build:dev": "npx eas build -p android --profile development",
    "checksum": "bash generate-checksum.sh",
    "generate-api": "npx openapi-typescript openapi.json -o src/types/api.ts",
    "test": "jest"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.ts"
    ]
  },
  "dependencies": {
    "@expo-google-fonts/bangers": "^0.4.1",
    "@expo/vector-icons": "^15.0.3",
    "@fontsource/bangers": "^5.2.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.8",
    "@tanstack/react-query": "^5.100.9",
    "axios": "^1.16.0",
    "date-fns": "^4.1.0",
    "eas-cli": "^18.12.1",
    "expo": "~54.0.33",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-modules-core": "~3.0.30",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "^55.0.17",
    "expo-web-browser": "~15.0.10",
    "lucide-react-native": "^1.14.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "axios-mock-adapter": "^2.1.0",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.17",
    "openapi-typescript": "^7.13.0",
    "react-test-renderer": "19.1.0",
    "swagger2openapi": "^7.0.8",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.2"
  },
  "private": true
}